import java.util.*;

public class TransactionProcessor {
    static class Transaction {
        int id;
        int amount;
        String merchant;
        long timestamp;
        String accountId;

        Transaction(int id, int amount, String merchant, long timestamp, String accountId) {
            this.id = id;
            this.amount = amount;
            this.merchant = merchant;
            this.timestamp = timestamp;
            this.accountId = accountId;
        }
    }

    public List<String> findTwoSum(List<Transaction> transactions, int target) {
        Map<Integer, Integer> map = new HashMap<>();
        List<String> results = new ArrayList<>();
        for (Transaction t : transactions) {
            int complement = target - t.amount;
            if (map.containsKey(complement)) {
                results.add("(id:" + map.get(complement) + ", id:" + t.id + ")");
            }
            map.put(t.amount, t.id);
        }
        return results;
    }

    public List<String> findTwoSumWithTimeWindow(List<Transaction> transactions, int target, long windowMillis) {
        Map<Integer, Transaction> map = new HashMap<>();
        List<String> results = new ArrayList<>();
        for (Transaction t : transactions) {
            int complement = target - t.amount;
            if (map.containsKey(complement)) {
                Transaction prev = map.get(complement);
                if (Math.abs(t.timestamp - prev.timestamp) <= windowMillis) {
                    results.add("(id:" + prev.id + ", id:" + t.id + ")");
                }
            }
            map.put(t.amount, t);
        }
        return results;
    }

    public List<Map<String, Object>> detectDuplicates(List<Transaction> transactions) {
        Map<String, List<String>> map = new HashMap<>();
        List<Map<String, Object>> duplicates = new ArrayList<>();
        
        for (Transaction t : transactions) {
            String key = t.amount + "_" + t.merchant;
            map.computeIfAbsent(key, k -> new ArrayList<>()).add(t.accountId);
        }

        for (Map.Entry<String, List<String>> entry : map.entrySet()) {
            if (entry.getValue().size() > 1) {
                String[] parts = entry.getKey().split("_");
                Map<String, Object> dup = new HashMap<>();
                dup.put("amount", parts[0]);
                dup.put("merchant", parts[1]);
                dup.put("accounts", entry.getValue());
                duplicates.add(dup);
            }
        }
        return duplicates;
    }

    public List<List<Integer>> findKSum(List<Transaction> transactions, int k, int target) {
        transactions.sort(Comparator.comparingInt(t -> t.amount));
        return kSumHelper(transactions, k, target, 0);
    }

    private List<List<Integer>> kSumHelper(List<Transaction> transactions, int k, int target, int start) {
        List<List<Integer>> res = new ArrayList<>();
        if (start == transactions.size()) return res;

        if (k == 2) {
            int left = start, right = transactions.size() - 1;
            while (left < right) {
                int sum = transactions.get(left).amount + transactions.get(right).amount;
                if (sum == target) {
                    res.add(new ArrayList<>(Arrays.asList(transactions.get(left).id, transactions.get(right).id)));
                    while (left < right && transactions.get(left).amount == transactions.get(left + 1).amount) left++;
                    while (left < right && transactions.get(right).amount == transactions.get(right - 1).amount) right--;
                    left++; right--;
                } else if (sum < target) left++;
                else right--;
            }
        } else {
            for (int i = start; i < transactions.size() - k + 1; i++) {
                List<List<Integer>> temp = kSumHelper(transactions, k - 1, target - transactions.get(i).amount, i + 1);
                for (List<Integer> t : temp) {
                    t.add(0, transactions.get(i).id);
                    res.add(t);
                }
                while (i < transactions.size() - 1 && transactions.get(i).amount == transactions.get(i + 1).amount) i++;
            }
        }
        return res;
    }

    public static void main(String[] args) {
        TransactionProcessor processor = new TransactionProcessor();
        List<Transaction> txns = Arrays.asList(
            new Transaction(1, 500, "Store A", 1000, "acc1"),
            new Transaction(2, 300, "Store B", 2000, "acc2"),
            new Transaction(3, 200, "Store C", 3000, "acc3"),
            new Transaction(4, 500, "Store A", 4000, "acc4")
        );

        System.out.println("Two Sum: " + processor.findTwoSum(txns, 500));
        System.out.println("Duplicates: " + processor.detectDuplicates(txns));
        System.out.println("3-Sum: " + processor.findKSum(txns, 3, 1000));
    }
}
