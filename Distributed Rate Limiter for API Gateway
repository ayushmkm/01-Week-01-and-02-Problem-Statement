import java.util.Map;
import java.util.concurrent.ConcurrentHashMap;
import java.util.concurrent.atomic.AtomicLong;

public class DistributedRateLimiter {
    private final Map<String, TokenBucket> clientLimits = new ConcurrentHashMap<>();
    private final int MAX_TOKENS = 1000;
    private final long REFILL_INTERVAL_MS = 3600000; 

    private class TokenBucket {
        private final AtomicLong tokens;
        private volatile long lastRefillTime;

        public TokenBucket() {
            this.tokens = new AtomicLong(MAX_TOKENS);
            this.lastRefillTime = System.currentTimeMillis();
        }

        public synchronized boolean tryConsume() {
            refill();
            long currentTokens = tokens.get();
            if (currentTokens > 0) {
                tokens.decrementAndGet();
                return true;
            }
            return false;
        }

        private void refill() {
            long now = System.currentTimeMillis();
            if (now > lastRefillTime + REFILL_INTERVAL_MS) {
                tokens.set(MAX_TOKENS);
                lastRefillTime = now;
            }
        }

        public long getRemaining() {
            refill();
            return tokens.get();
        }

        public long getNextResetSeconds() {
            long nextReset = lastRefillTime + REFILL_INTERVAL_MS;
            return Math.max(0, (nextReset - System.currentTimeMillis()) / 1000);
        }
    }

    public void checkRateLimit(String clientId) {
        TokenBucket bucket = clientLimits.computeIfAbsent(clientId, k -> new TokenBucket());

        if (bucket.tryConsume()) {
            System.out.println("Allowed (" + bucket.getRemaining() + " requests remaining)");
        } else {
            System.out.println("Denied (0 requests remaining, retry after " + bucket.getNextResetSeconds() + "s)");
        }
    }

    public static void main(String[] args) {
        DistributedRateLimiter limiter = new DistributedRateLimiter();
        String clientId = "abc123";

        for (int i = 0; i < 1002; i++) {
            limiter.checkRateLimit(clientId);
        }
    }
}
